# ─────────────────────────────────────────
#  Database
# ─────────────────────────────────────────
POSTGRES_DB=blurrtools
POSTGRES_USER=blurrtools
POSTGRES_PASSWORD=changeme_strong_password_here

# Used by api and worker inside Docker network (host = postgres)
DATABASE_URL=postgresql://blurrtools:changeme_strong_password_here@postgres:5432/blurrtools

# Used for local dev (docker-compose.dev.yml maps postgres to localhost:5433)
# DATABASE_URL=postgresql://blurrtools:changeme_strong_password_here@localhost:5433/blurrtools

# ─────────────────────────────────────────
#  Redis
# ─────────────────────────────────────────
# Inside Docker network
REDIS_URL=redis://redis:6379

# Local dev (docker-compose.dev.yml maps redis to localhost:6380)
# REDIS_URL=redis://localhost:6380

# ─────────────────────────────────────────
#  JWT
# ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex_string
JWT_REFRESH_SECRET=replace_with_another_64_byte_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────
#  Server
# ─────────────────────────────────────────
NODE_ENV=production
API_PORT=3000

# ─────────────────────────────────────────
#  Shopify
# ─────────────────────────────────────────
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# ─────────────────────────────────────────
#  Google Sheets
# ─────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/run/secrets/google-sa-key.json
# Or inline JSON:
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

DAILY_ORDERS_SPREADSHEET_ID=your_spreadsheet_id_here
VITE_DAILY_ORDERS_SHEET_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id_here
DAILY_ORDERS_SCHEDULE_CRON=0 8 * * *
DAILY_ORDERS_SCHEDULE_TZ=America/New_York

# ─────────────────────────────────────────
#  Email (SMTP — Hostinger)
# ─────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@yourdomain.com
SMTP_PASS=your_smtp_password_here
EMAIL_FROM_NAME=Blurr Tools
APP_URL=https://yourdomain.com

# ─────────────────────────────────────────
#  Caddy (production only)
# ─────────────────────────────────────────
DOMAIN=yourdomain.com
CADDY_EMAIL=admin@yourdomain.com
